window.PORTFOLIO = (function () {
  const ids = [
    "agr_inbound_42","agr_412c","agr_88a1","agr_5e2f","agr_2c19","agr_4d80","agr_99f1","agr_44b2",
    "agr_07ab","agr_3d77","agr_7711","agr_a012","agr_b1c2","agr_c2d3","agr_d3e4","agr_e4f5",
    "agr_f506","agr_0617","agr_1728","agr_2839","agr_394a","agr_4a5b","agr_5b6c","agr_6c7d",
  ];
  const names = [
    "Northwind","Globex","Soylent","Initech","Umbrella","Hooli","Pied Piper","Stark",
    "Wayne Ent.","Cyberdyne","Wonka","Acme Corp","Vandelay","Dunder","Sterling C.","Tyrell",
    "Aperture","Massive Dyn.","BluthCo","Hammer Ind.","Oscorp","LexCorp","Wayne Tech","Gringotts",
  ];
  const rules = ["r_001","r_002","r_003","r_004","r_005","r_006","r_007"];
  const sevs = ["pass","info","warn","approval_required","blocker"];
  function rng(seed) { let x = seed; return () => { x = (x * 9301 + 49297) % 233280; return x / 233280; }; }
  const r = rng(7);
  return ids.map((id, i) => {
    const cells = rules.map(rid => {
      const v = r();
      let s;
      if (id === "agr_inbound_42") {
        s = ({ r_001: "pass", r_002: "approval_required", r_003: "warn", r_004: "approval_required", r_005: "pass", r_006: "pass", r_007: "blocker" })[rid];
      } else if (v < 0.55) s = "pass";
      else if (v < 0.75) s = "info";
      else if (v < 0.88) s = "warn";
      else if (v < 0.97) s = "approval_required";
      else s = "blocker";
      return { rule_id: rid, severity: s };
    });
    return { id, name: names[i], cells };
  });
})();

